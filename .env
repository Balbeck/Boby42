
# # * * * [ Dev ] * * *
# CORS_ORIGIN=http://localhost:8421






# # =============================================================================
# # .env — point d'entrée unique des variables d'environnement du projet
# # (backend + frontend). Ces variables sont injectées dans chaque conteneur
# # via les blocs `environment:` de docker-compose.yml (substitution ${VAR:-...}).
# #
# # Deux sections ci-dessous : PROD (active) et DEV (désactivée, commentée).
# # Pour passer en dev : commenter entièrement la section PROD, décommenter
# # entièrement la section DEV. Ne jamais activer les deux blocs en même temps
# # (mêmes clés dans les deux → conflit).
# # =============================================================================

# # ─────────────────────────────── [ PROD ] — active ───────────────────────────

# # # - - - [ Backend / Server ] - - -
# # PORT=8420
# # CORS_ORIGIN=https://42gpt.42ai.net # prod

# # # - - - [ Backend / Ollama ] - - -
# # OLLAMA_BASE_URL=http://localhost:11434
# # OLLAMA_GENERATION_MODEL=mistral:latest
# # OLLAMA_EMBEDDING_MODEL=snowflake-arctic-embed:335m

# # # - - - [ Frontend ] - - -
# # FRONTEND_PORT=8421
# # VITE_ALLOWED_HOSTS=42gpt.42ai.net
# # VITE_PROXY_TARGET=http://localhost:8420
# # # VITE_API_URL= # laissé vide : chemin relatif /chat, relayé par le proxy Vite

# # ─────────────────────────────── [ DEV ] — désactivée ────────────────────────

# # - - - [ Backend / Server ] - - -
# PORT=8420
# CORS_ORIGIN=http://localhost:8421 # dev

# # - - - [ Backend / Ollama ] - - -
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_GENERATION_MODEL=mistral:latest
# OLLAMA_EMBEDDING_MODEL=snowflake-arctic-embed:335m

# # - - - [ Frontend ] - - -
# FRONTEND_PORT=8421
# VITE_ALLOWED_HOSTS=localhost
# VITE_PROXY_TARGET=http://127.0.0.1:8420
# VITE_API_URL=http://localhost:8420
